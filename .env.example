PORT=3001
JWT_SECRET=changeme
JWT_EXPIRES_MINUTES=1440
DATABASE_URL=sqlite+aiosqlite:///data/interview.db

# CodeVector OpenAI-compatible endpoint
CODEVECTOR_BASE_URL=https://coding-gateway.fissionlabs.com/gateway/openai/v1
CODEVECTOR_API_KEY=your-key-here
CODEVECTOR_MODEL=kimi-k2.6

# LLM Gateway rate limiting (requests per minute per user)
GATEWAY_RATE_LIMIT_RPM=60
GATEWAY_JWT_ISSUER=         # optional JWT issuer validation

FRONTEND_URL=http://localhost:8080

# Email — sent when an interview is scheduled (Gmail: use an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true

# IANA timezone used to display interview times in emails
DISPLAY_TIMEZONE=Asia/Kolkata

# Host directory where IDE containers write session logs (and the backend reads
# them for scoring). Defaults to <repo>/web-ide/workspaces; override if needed.
# WORKSPACE_DIR=C:\path\to\coderbit\web-ide\workspaces
