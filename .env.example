PORT=3001
# Must be at least 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_replace_with_32_plus_char_secret
JWT_EXPIRES_MINUTES=1440
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/interview_db



# Fernet key for encrypting auth_token at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── AWS Credentials ────────────────────────────────────────────────────────────
# The backend uses these directly via boto3.Session (not pushed into os.environ).
# Required when MICROVM_IMAGE_ARN is set and the backend needs to manage Lambda
# MicroVMs (create, token refresh, terminate).
AWS_DEFAULT_REGION=us-west-2
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=                       # Omit if using long-lived IAM user keys

# IAM Role ARN the backend assumes via STS to issue short-lived upload
# credentials to MicroVMs. The role must allow s3:PutObject/GetObject on
# S3_CANDIDATE_LOGS_BUCKET. Required when MICROVM_IMAGE_ARN is set.
MICROVM_UPLOAD_ROLE_ARN=arn:aws:iam::<account-id>:role/coderbit-microvm-upload

# ── MicroVM resource limits ──────────────────────────────────────────────────
# Memory cap applied to the MicroVM image via UpdateMicrovmImage (MiB). Default: 2048.
# MICROVM_MEMORY_MIB=2048

# Hard wall-clock cap for each MicroVM session (seconds). AWS terminates the VM
# after this duration regardless of activity. Default: 14400 (4 hours).
# MICROVM_MAX_DURATION_SECONDS=14400

# Disk write quota enforced inside the MicroVM via a sparse sentinel file (MB). Default: 2048.
# MICROVM_DISK_QUOTA_MB=2048

# Max processes/threads the candidate user may create (cgroup pids.max + ulimit -u). Default: 256.
# MICROVM_MAX_PIDS=256

# Lifetime of the AWS MicroVM auth token (minutes). AWS currently caps this at
# 60 via the API; setting a higher value causes CreateMicrovmAuthToken to fail.
# The live WebSocket carries this token in its connect subprotocol — the backend
# cannot refresh it mid-session, so the session effectively has a 60-minute
# limit. Default and maximum: 60.
# MICROVM_TOKEN_TTL_MINUTES=60

# Number of days before candidate artifacts (recordings, logs, workspace zips)
# are automatically expired by the S3 lifecycle rule. Default: 90.
# S3_ARTIFACT_RETENTION_DAYS=90

# CodeVector OpenAI-compatible endpoint (used by LLM gateway proxy)
CODEVECTOR_BASE_URL=https://coding-gateway.fissionlabs.com/gateway/openai/v1
CODEVECTOR_API_KEY=your-key-here
CODEVECTOR_MODEL=kimi-k2.6

# Scoring pipeline LLM — defaults to CODEVECTOR_* values if not set.
# Override to use a different model/endpoint for the multi-judge scoring pipeline.
# SCORING_BASE_URL=https://coding-gateway.fissionlabs.com/gateway/openai/v1
# SCORING_API_KEY=your-scoring-key-here
# SCORING_MODEL=kimi-k2.6

# LLM Gateway rate limiting (requests per minute per user)
GATEWAY_RATE_LIMIT_RPM=60
GATEWAY_JWT_ISSUER=         # optional JWT issuer validation

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# AWS Lambda MicroVMs
MICROVM_IMAGE_ARN=
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Email — sent when an interview is scheduled (Gmail: use an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true

# IANA timezone used to display interview times in emails
DISPLAY_TIMEZONE=Asia/Kolkata

# Host directory where IDE containers write session logs (and the backend reads
# them for scoring). Defaults to <repo>/web-ide/workspaces; override if needed.
# WORKSPACE_DIR=C:\path\to\coderbit\web-ide\workspaces
